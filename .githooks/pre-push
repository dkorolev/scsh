#!/bin/sh
# Fast local development gate. CI remains exhaustive across debug and release profiles.
# Enable once per clone with: git config core.hooksPath .githooks
set -e
cd "$(git rev-parse --show-toplevel)"
export RUSTFLAGS='-D warnings'
cargo fmt --check
cargo clippy --all-targets -- -D warnings
cargo build

# Unit tests need the standalone debug binary built above. Run both Rust suites and the
# release-gate self-tests concurrently, preserving every command's live output and result.
cargo test --bin scsh &
unit_pid=$!
cargo test --test cli &
integration_pid=$!
python3 -m unittest discover -s scripts -p 'test_*.py' &
release_gate_pid=$!

cleanup() {
  [ -z "${unit_pid:-}" ] || kill "$unit_pid" 2>/dev/null || true
  [ -z "${integration_pid:-}" ] || kill "$integration_pid" 2>/dev/null || true
  [ -z "${release_gate_pid:-}" ] || kill "$release_gate_pid" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# The release-shape comparison itself is PR-only: a local hook is not given GitHub's
# chosen base SHA, so scripts/check-release.py runs in CI instead.
status=0
wait "$unit_pid" || status=1
unit_pid=
wait "$integration_pid" || status=1
integration_pid=
wait "$release_gate_pid" || status=1
release_gate_pid=
trap - EXIT INT TERM
exit "$status"
