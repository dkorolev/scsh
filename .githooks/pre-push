#!/bin/sh
# Fast local development gate. CI remains exhaustive across debug and release profiles.
# Enable once per clone with: git config core.hooksPath .githooks
set -e
cd "$(git rev-parse --show-toplevel)"
export RUSTFLAGS='-D warnings'
cargo fmt --check
cargo clippy --all-targets -- -D warnings
cargo build

# Unit tests need the standalone debug binary built above. Run both Rust suites and the
# GitHub-gate self-tests concurrently, preserving every command's live output and result.
cargo test --bin scsh &
unit_pid=$!
cargo test --test cli &
integration_pid=$!
python3 -m unittest discover -s scripts -p 'test_*.py' &
github_gate_pid=$!

cleanup() {
  [ -z "${unit_pid:-}" ] || kill "$unit_pid" 2>/dev/null || true
  [ -z "${integration_pid:-}" ] || kill "$integration_pid" 2>/dev/null || true
  [ -z "${github_gate_pid:-}" ] || kill "$github_gate_pid" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# The PR-range checks themselves are CI-only: a local hook is not given GitHub's chosen
# base and head SHAs, so the scripts exercise only their deterministic self-tests here.
status=0
wait "$unit_pid" || status=1
unit_pid=
wait "$integration_pid" || status=1
integration_pid=
wait "$github_gate_pid" || status=1
github_gate_pid=
trap - EXIT INT TERM
exit "$status"
